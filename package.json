{
  "name": "finguide",
  "version": "1.0.0",
  "description": "Книга по открытым государственным финансам России на Docusaurus",
  "scripts": {
    "start": "docusaurus start",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "deploy": "docusaurus deploy",
    "swizzle": "docusaurus swizzle",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint:frontmatter": "node scripts/frontmatter-lint.mjs",
    "lint:howto": "node scripts/howto-structure-lint.mjs",
    "lint:qa": "node scripts/validate-qa-jsonl.mjs",
    "qa:retrieval": "node scripts/qa-retrieval-regression.mjs",
    "audit:corpus": "node scripts/audit-corpus-governance.mjs",
    "migrate:source-metadata": "node scripts/migrate-source-metadata.mjs",
    "migrate:govngo-lifecycle": "node scripts/migrate-govngo-lifecycle.mjs",
    "fix:malformed-urls": "node scripts/fix-malformed-external-urls.mjs",
    "write:import-family-hubs": "node scripts/write-import-family-hubs.mjs",
    "lint:corpus": "node scripts/corpus-markdown-lint.mjs",
    "lint:url-syntax": "node scripts/url-syntax-lint.mjs",
    "lint:related-pages": "node scripts/validate-related-pages.mjs",
    "test:knowledge-export": "node --test tests/knowledge-export.test.mjs",
    "test:url-syntax": "node --test tests/url-syntax-lint.test.mjs",
    "export:knowledge": "node scripts/export-knowledge-index.mjs",
    "inject:related-pages": "node scripts/inject-related-pages-wave.mjs",
    "generate:budget-gov-opendata-cards": "node scripts/generate-budget-gov-opendata-dataset-cards.mjs",
    "generate:fns-opendata-cards": "node scripts/generate-fns-opendata-cards.mjs",
    "bootstrap:regional": "node scripts/bootstrap-regional-wiki.mjs",
    "import:regional-table": "node scripts/import-regional-sources-from-table.mjs",
    "import:federal-gov-orgs": "node scripts/import-federal-gov-orgs-from-xlsx.mjs",
    "reorganize:enterprises-subgroups": "node scripts/reorganize-enterprises-subgroups.mjs",
    "import:federal-gos-ngo": "node scripts/import-federal-gos-ngo-from-xlsx.mjs",
    "patch:gosnko-org-about": "node scripts/patch-gosnko-org-about.mjs",
    "build:federal-gos-ngo-registry": "node scripts/build-federal-gos-ngo-registry.mjs",
    "write:federal-gos-ngo-indexes": "node scripts/write-federal-gos-ngo-indexes.mjs",
    "fix:regional-fin-sidebar-labels": "node scripts/fix-regional-fin-sidebar-labels.mjs",
    "refresh:budget-gov-opendata-sidebar-labels": "node scripts/refresh-budget-gov-opendata-sidebar-labels.mjs",
    "presubmit": "npm run lint:frontmatter && npm run lint:howto && npm run lint:url-syntax && npm run test:knowledge-export && npm run test:url-syntax && npm run audit:corpus -- --check && npm run export:knowledge -- --check && npm run lint:qa && npm run qa:retrieval && npm run lint:related-pages && npm run lint:corpus && npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infoculture/finguide.git"
  },
  "keywords": [
    "opengov",
    "finance",
    "russia",
    "wiki",
    "docusaurus"
  ],
  "author": "Infoculture",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/infoculture/finguide/issues"
  },
  "homepage": "https://infoculture.github.io/finguide/",
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "github-slugger": "^1.5.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "gray-matter": "^4.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
